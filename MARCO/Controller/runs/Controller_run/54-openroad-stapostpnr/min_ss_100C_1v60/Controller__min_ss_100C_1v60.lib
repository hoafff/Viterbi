library (Controller) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 100.0;
  nom_voltage                    : 1.60;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
  }

  cell ("Controller") {
    area : 666.890 
    is_macro_cell : true;
    pin("clk") {
      direction : input;
      clock : true;
      capacitance : 0.0104;
      timing() {
        timing_sense : positive_unate;
        timing_type : min_clock_tree_path;
	cell_rise(scalar) {
          values("0.48281");
	}
	cell_fall(scalar) {
          values("0.50642");
	}
      }
      timing() {
        timing_sense : positive_unate;
        timing_type : max_clock_tree_path;
	cell_rise(scalar) {
          values("0.48750");
	}
	cell_fall(scalar) {
          values("0.51066");
	}
      }
    }
    pin("clr_me") {
      direction : output;
      capacitance : 0.0009;
      timing() {
        related_pin : "start";
        timing_sense : negative_unate;
        timing_type : combinational;
	cell_rise(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.98493,0.99537,1.02272,1.09527,1.32101,2.06244,4.51749");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03278,0.04153,0.06834,0.15833,0.47301,1.52727,5.00470");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.70787,0.71778,0.74184,0.79545,0.93139,1.35274,2.74586");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03261,0.03940,0.05709,0.10706,0.27043,0.84131,2.74469");
	}
      }
    }
    pin("frame_done") {
      direction : output;
      capacitance : 0.0004;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("2.28840,2.29851,2.32534,2.39762,2.62338,3.36501,5.81870");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03123,0.04008,0.06711,0.15774,0.47313,1.52790,5.00362");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("2.16499,2.17492,2.19894,2.25267,2.38865,2.81022,4.20410");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03267,0.03937,0.05712,0.10713,0.27053,0.84146,2.74589");
	}
      }
    }
    pin("rst_n") {
      direction : input;
      capacitance : 0.0031;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.87238");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.54905");
	}
      }
    }
    pin("start") {
      direction : input;
      capacitance : 0.0026;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.78949");
	}
	fall_constraint(scalar) {
          values("-0.22107");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.85630");
	}
	fall_constraint(scalar) {
          values("0.40886");
	}
      }
    }
  }

}
