library (Controller) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 25.0;
  nom_voltage                    : 1.80;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
  }

  cell ("Controller") {
    area : 666.890 
    is_macro_cell : true;
    pin("clk") {
      direction : input;
      clock : true;
      capacitance : 0.0104;
      timing() {
        timing_sense : positive_unate;
        timing_type : min_clock_tree_path;
	cell_rise(scalar) {
          values("0.27552");
	}
	cell_fall(scalar) {
          values("0.28200");
	}
      }
      timing() {
        timing_sense : positive_unate;
        timing_type : max_clock_tree_path;
	cell_rise(scalar) {
          values("0.27829");
	}
	cell_fall(scalar) {
          values("0.28435");
	}
      }
    }
    pin("clr_me") {
      direction : output;
      capacitance : 0.0009;
      timing() {
        related_pin : "start";
        timing_sense : negative_unate;
        timing_type : combinational;
	cell_rise(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.54331,0.54863,0.56113,0.59084,0.67122,0.90395,1.59540");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.01997,0.02420,0.03617,0.07235,0.18501,0.52165,1.50734");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.36312,0.36801,0.37829,0.39937,0.44469,0.56081,0.89519");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.01780,0.02057,0.02791,0.04572,0.09386,0.24219,0.69492");
	}
      }
    }
    pin("frame_done") {
      direction : output;
      capacitance : 0.0004;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("1.20058,1.20574,1.21798,1.24749,1.32790,1.56025,2.25486");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.01897,0.02326,0.03538,0.07191,0.18500,0.52140,1.50781");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("1.11857,1.12333,1.13359,1.15467,1.20006,1.31622,1.65094");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00146,  0.00429,  0.01257,  0.03681,  0.10783,  0.31587");
          values("0.01778,0.02064,0.02792,0.04569,0.09385,0.24224,0.69637");
	}
      }
    }
    pin("rst_n") {
      direction : input;
      capacitance : 0.0032;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.43217");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.27070");
	}
      }
    }
    pin("start") {
      direction : input;
      capacitance : 0.0027;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.31261");
	}
	fall_constraint(scalar) {
          values("-0.07690");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.34417");
	}
	fall_constraint(scalar) {
          values("0.14869");
	}
      }
    }
  }

}
