library (Controller) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : 100.0;
  nom_voltage                    : 1.60;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
  }

  cell ("Controller") {
    area : 666.890 
    is_macro_cell : true;
    pin("clk") {
      direction : input;
      clock : true;
      capacitance : 0.0108;
      timing() {
        timing_sense : positive_unate;
        timing_type : min_clock_tree_path;
	cell_rise(scalar) {
          values("0.48975");
	}
	cell_fall(scalar) {
          values("0.51153");
	}
      }
      timing() {
        timing_sense : positive_unate;
        timing_type : max_clock_tree_path;
	cell_rise(scalar) {
          values("0.49478");
	}
	cell_fall(scalar) {
          values("0.51604");
	}
      }
    }
    pin("clr_me") {
      direction : output;
      capacitance : 0.0010;
      timing() {
        related_pin : "start";
        timing_sense : negative_unate;
        timing_type : combinational;
	cell_rise(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.99513,1.00558,1.03294,1.10549,1.33122,2.07265,4.52771");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03279,0.04155,0.06835,0.15834,0.47301,1.52726,5.00471");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.71955,0.72945,0.75351,0.80712,0.94307,1.36442,2.75756");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03261,0.03940,0.05709,0.10706,0.27043,0.84132,2.74472");
	}
      }
    }
    pin("frame_done") {
      direction : output;
      capacitance : 0.0005;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("2.33220,2.34244,2.36948,2.44186,2.66762,3.40917,5.86339");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03184,0.04065,0.06759,0.15797,0.47308,1.52765,5.00405");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("2.20343,2.21336,2.23738,2.29113,2.42712,2.84875,4.24281");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00166,  0.00551,  0.01830,  0.06076,  0.20175,  0.66987");
          values("0.03268,0.03937,0.05713,0.10715,0.27056,0.84149,2.74617");
	}
      }
    }
    pin("rst_n") {
      direction : input;
      capacitance : 0.0032;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.87370");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.54095");
	}
      }
    }
    pin("start") {
      direction : input;
      capacitance : 0.0027;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.80530");
	}
	fall_constraint(scalar) {
          values("-0.22996");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.87148");
	}
	fall_constraint(scalar) {
          values("0.41769");
	}
      }
    }
  }

}
