library (Controller) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1A";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : -40.0;
  nom_voltage                    : 1.95;

  lu_table_template(template_1) {
    variable_1 : total_output_net_capacitance;
    index_1("0.00050,  0.00153,  0.00471,  0.01445,  0.04434,  0.13605,  0.41749");
  }

  cell ("Controller") {
    area : 666.890 
    is_macro_cell : true;
    pin("clk") {
      direction : input;
      clock : true;
      capacitance : 0.0109;
      timing() {
        timing_sense : positive_unate;
        timing_type : min_clock_tree_path;
	cell_rise(scalar) {
          values("0.19275");
	}
	cell_fall(scalar) {
          values("0.19231");
	}
      }
      timing() {
        timing_sense : positive_unate;
        timing_type : max_clock_tree_path;
	cell_rise(scalar) {
          values("0.19515");
	}
	cell_fall(scalar) {
          values("0.19440");
	}
      }
    }
    pin("clr_me") {
      direction : output;
      capacitance : 0.0010;
      timing() {
        related_pin : "start";
        timing_sense : negative_unate;
        timing_type : combinational;
	cell_rise(template_1) {
          index_1("0.00050,  0.00153,  0.00471,  0.01445,  0.04434,  0.13605,  0.41749");
          values("0.36585,0.37006,0.38001,0.40518,0.47856,0.70473,1.39307");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00153,  0.00471,  0.01445,  0.04434,  0.13605,  0.41749");
          values("0.01532,0.01861,0.02810,0.06019,0.16603,0.49714,1.51036");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00153,  0.00471,  0.01445,  0.04434,  0.13605,  0.41749");
          values("0.24311,0.24648,0.25445,0.27129,0.30953,0.41433,0.73352");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00153,  0.00471,  0.01445,  0.04434,  0.13605,  0.41749");
          values("0.01268,0.01508,0.02085,0.03523,0.07666,0.21255,0.63939");
	}
      }
    }
    pin("frame_done") {
      direction : output;
      capacitance : 0.0005;
      timing() {
        related_pin : "clk";
        timing_type : rising_edge;
	cell_rise(template_1) {
          index_1("0.00050,  0.00153,  0.00471,  0.01445,  0.04434,  0.13605,  0.41749");
          values("0.81564,0.81982,0.82975,0.85490,0.92829,1.15448,1.84296");
	}
	rise_transition(template_1) {
          index_1("0.00050,  0.00153,  0.00471,  0.01445,  0.04434,  0.13605,  0.41749");
          values("0.01518,0.01848,0.02800,0.06015,0.16604,0.49713,1.51036");
	}
	cell_fall(template_1) {
          index_1("0.00050,  0.00153,  0.00471,  0.01445,  0.04434,  0.13605,  0.41749");
          values("0.74774,0.75111,0.75909,0.77595,0.81420,0.91900,1.23880");
	}
	fall_transition(template_1) {
          index_1("0.00050,  0.00153,  0.00471,  0.01445,  0.04434,  0.13605,  0.41749");
          values("0.01287,0.01528,0.02099,0.03531,0.07668,0.21229,0.64282");
	}
      }
    }
    pin("rst_n") {
      direction : input;
      capacitance : 0.0033;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("0.27328");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("-0.16863");
	}
      }
    }
    pin("start") {
      direction : input;
      capacitance : 0.0028;
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.16435");
	}
	fall_constraint(scalar) {
          values("-0.03243");
	}
      }
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.18187");
	}
	fall_constraint(scalar) {
          values("0.07645");
	}
      }
    }
  }

}
